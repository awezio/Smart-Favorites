{
  "functions": {
    "app/api/chat/route.ts": {
      "maxDuration": 300
    },
    "app/api/bookmarks/snapshot-page/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/cron/process-snapshots/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/ai/describe/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/process-snapshots?limit=2",
      "schedule": "*/5 * * * *"
    }
  ]
}
