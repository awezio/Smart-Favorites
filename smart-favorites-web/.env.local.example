# Supabase Configuration (必需)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encrypt user-entered AI provider API keys before storing them in Supabase.
# Use one stable random value per deployment; changing it makes saved user keys unreadable.
USER_API_KEY_ENCRYPTION_SECRET=replace-with-a-long-random-secret

# AI/LLM Provider Configuration (至少配置一个)
# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# DeepSeek (推荐，性价比高)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Kimi (月之暗面)
KIMI_API_KEY=your-kimi-key

# Qwen (阿里通义千问)
QWEN_API_KEY=sk-your-qwen-key

# Claude (Anthropic)
CLAUDE_API_KEY=sk-ant-your-claude-key

# Gemini (Google)
GEMINI_API_KEY=your-gemini-key

# GLM (智谱AI)
GLM_API_KEY=your-glm-key

# Ollama (本地部署)
OLLAMA_BASE_URL=http://localhost:11434

# Default LLM Provider (可选值: openai, deepseek, kimi, qwen, claude, gemini, glm, ollama)
DEFAULT_LLM_PROVIDER=deepseek

# Embedding Configuration (可选，默认使用 Xenova/all-MiniLM-L6-v2)
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
# 如果使用 OpenAI embeddings:
# USE_OPENAI_EMBEDDINGS=true
# Existing pgvector columns are vector(384), so OpenAI embeddings are requested with dimensions=384.
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# GitHub Configuration (可选，用于提高 GitHub API 限制)
GITHUB_TOKEN=ghp_your-github-token

# Smart Favorites 浏览器扩展 ID（可选，逗号分隔多个候选 ID）
NEXT_PUBLIC_SMART_FAVORITES_EXTENSION_IDS=bmmjjmpmhadcoebhenfhielebpollmnn

# Application Configuration
NODE_ENV=development
